# Configuration du Serveur
PORT=3000
NODE_ENV=development
# Origines autorisées par CORS (séparées par virgule, sans espaces)
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# Configuration Base de données (Supabase)
SUPABASE_URL=http://127.0.0.1:54321
SUPABASE_ANON_KEY=votre_cle_publique_anon
SUPABASE_SERVICE_ROLE_KEY=votre_cle_de_service_secrete

# Firebase Admin SDK (Chemin vers votre fichier JSON de clé privée)
GOOGLE_APPLICATION_CREDENTIALS=./firebase-key.json

# FedaPay Security
FEDAPAY_SECRET_KEY=votre_cle_secrete_fedapay
FEDAPAY_WEBHOOK_SECRET=votre_secret_webhook

# JWT (OBLIGATOIRE - utilisé pour les tokens Partenaires)
# Générer avec : node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=votre_secret_jwt_tres_long_et_aleatoire

# Administration
ADMIN_SUPABASE_UID=votre_uid_supabase_admin_pour_notifications
ADMIN_DASHBOARD_TOKEN=votre_token_admin_long_et_aleatoire

# MikroTik VPN (Future use)
# MIKROTIK_CONNECT_TIMEOUT=5000
