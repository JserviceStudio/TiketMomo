{
  "name": "tiketmomo",
  "version": "1.0.0",
  "description": "Backend Multi-Tenant pour la gestion de vouchers Wi-Fi via MikroTik",
  "main": "src/server.js",
  "type": "module",
  "scripts": {
    "start": "node src/server.js",
    "dev": "node --watch src/server.js",
    "analyze": "node scripts/analyze.js",
    "test": "node --test tests/**/*.test.js",
    "web:dev": "npm --prefix apps/web run dev",
    "web:build": "npm --prefix apps/web run build",
    "web:start": "npm --prefix apps/web run start",
    "web:lint": "npm --prefix apps/web run lint"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.98.0",
    "bcrypt": "^6.0.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "express-rate-limit": "^8.2.1",
    "fast-levenshtein": "^3.0.0",
    "helmet": "^8.0.0",
    "joi": "^17.13.3",
    "json2csv": "^6.0.0-alpha.2",
    "jsonwebtoken": "^9.0.3",
    "morgan": "^1.10.0",
    "node-cron": "^4.2.1",
    "pino": "^9.5.0",
    "pino-pretty": "^13.0.0"
  }
}
